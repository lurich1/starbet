# Get a free key at https://the-odds-api.com (500 requests/month)
ODDS_API_KEY=your_key_here

# Password gate for /admin/*. Leave unset to disable the admin section entirely.
ADMIN_PASSWORD=change-me

# Paystack (https://paystack.com) — get keys from Settings → API Keys & Webhooks
# Public key ships to the browser (safe), secret key stays server-side.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx

# Minimum first deposit in GHS
MIN_FIRST_DEPOSIT=200

# Supabase (https://supabase.com) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never commit; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
