# API-Football (https://www.api-football.com) — Pro plan or higher needed for
# the live-odds endpoints. Sign in → Dashboard → API key. IMPORTANT: under
# "My Access", remove any IP allow-list — Vercel Functions use dynamic IPs
# that cannot be whitelisted reliably and the API will reject every call
# with `{ errors: { Ip: "This IP is not allowed..." } }`.
API_FOOTBALL_KEY=your_key_here

# Password gate for /admin/*. Leave unset to disable the admin section entirely.
ADMIN_PASSWORD=change-me

# Moolre — Ghana wallets only. The deposit route calls Moolre's
# `embed/src/start` API per transaction, gets a one-shot authorization
# URL, and redirects the player. After payment, Moolre POSTs the result
# to /api/payments/moolre/callback (HMAC-SHA256 signed with the Secret
# Key) and the player is auto-credited via applyDepositCredit.
#
# Setup:
#   1. Moolre dashboard → Security → Generate API Keys
#        copy Public Key into MOOLRE_PUBLIC_KEY
#   2. Moolre dashboard → Linked Wallet → Account No.
#        copy into MOOLRE_ACCOUNT_NUMBER
#   3. Moolre dashboard → Callbacks
#        set Callback URL to https://<your-app>/api/payments/moolre/callback
#        copy the Secret Key into MOOLRE_SECRET_KEY
MOOLRE_PUBLIC_KEY=
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_SECRET_KEY=

# Reserved for the payouts API. Not used by deposits or the webhook.
MOOLRE_PRIVATE_KEY=

# Flutterwave v3 (classic FLWSECK API) — deposits + the withdrawal fee via a
# mobile-money charge (on-phone PIN prompt for GH/KE) and hosted redirect for
# NG/ZA. Dashboard → Settings → API Keys.
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
# Encryption key — only needed if you later add direct card charges.
FLUTTERWAVE_ENCRYPTION_KEY=
# Dashboard → Settings → Webhooks: set the URL to
# https://<your-app>/api/payments/flutterwave/webhook and a "Secret hash".
# Paste that exact hash here — without it crediting relies on the browser poll
# only, so payments approved after the customer leaves the page won't credit.
FLUTTERWAVE_WEBHOOK_SECRET=

# Optional: absolute URL of this app (e.g. https://primebet.example.com)
# used to build the Paystack callback. Defaults to the request origin.
NEXT_PUBLIC_APP_URL=

# Minimum first deposit — legacy single-number var still applies to Ghana
# users. Other countries default to the values in lib/countries.ts; override
# per country with MIN_FIRST_DEPOSIT_NG, MIN_FIRST_DEPOSIT_KE,
# MIN_FIRST_DEPOSIT_ZA. Same pattern for VERIFICATION_AMOUNT_<CC>.
MIN_FIRST_DEPOSIT=200
# MIN_FIRST_DEPOSIT_NG=30000
# MIN_FIRST_DEPOSIT_KE=2500
# MIN_FIRST_DEPOSIT_ZA=350
# VERIFICATION_AMOUNT_GH=200
# VERIFICATION_AMOUNT_NG=30000
# VERIFICATION_AMOUNT_KE=2500
# VERIFICATION_AMOUNT_ZA=350

# Non-refundable fee (in the user's own currency) charged via Paystack before
# each withdrawal. Defaults to 620 for every country; override per country with
# WITHDRAWAL_FEE_<CC>.
# WITHDRAWAL_FEE_GH=620
# WITHDRAWAL_FEE_NG=620
# WITHDRAWAL_FEE_KE=620
# WITHDRAWAL_FEE_ZA=620

# Per-withdrawal amount band (in the user's own currency). Defaults: GH 1–30,
# others min 1 with no upper cap. WITHDRAWAL_MAX_<CC>=0 removes the cap.
# WITHDRAWAL_MIN_GH=1
# WITHDRAWAL_MAX_GH=30
# WITHDRAWAL_MIN_NG=1
# WITHDRAWAL_MAX_NG=0

# Supabase (https://supabase.com) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never commit; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Customer Service / Contact Support button → opens t.me/<handle>.
# Leave unset to default to "PrimeBet_Africa". Just the username, no @ or URL.
NEXT_PUBLIC_TELEGRAM_SUPPORT_HANDLE=PrimeBet_Africa

# Telegram operator-approval pay flow (Nigeria). The user taps "Pay via
# Telegram" on the deposit page → bot posts to the operator chat with
# Approve / Reject inline buttons → operator approves → user is credited
# via the normal applyDepositCredit pipeline.
#
# Setup (one-time):
#   1. In Telegram, message @BotFather → /newbot → follow the prompts.
#      Save the bot token it gives you into TELEGRAM_BOT_TOKEN.
#   2. Create or pick a group chat for operators (a 1:1 DM works too).
#      Add the bot. Send any message. Then visit:
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#      Find the chat.id in the JSON. Save it into TELEGRAM_ADMIN_CHAT_ID
#      (groups are negative numbers like -1001234567890, DMs are positive).
#   3. Generate a random string for TELEGRAM_WEBHOOK_SECRET (any 32+ chars).
#   4. After the app is deployed, register the webhook:
#        curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#          -H "Content-Type: application/json" \
#          -d '{
#                "url": "https://<your-app>/api/telegram/webhook",
#                "secret_token": "<TELEGRAM_WEBHOOK_SECRET>",
#                "allowed_updates": ["callback_query"]
#              }'
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
