# Get a free key at https://the-odds-api.com (500 requests/month)
ODDS_API_KEY=your_key_here

# Password gate for /admin/*. Leave unset to disable the admin section entirely.
ADMIN_PASSWORD=change-me

# Moolre POS link — Ghana wallets only. Hosted payment-page URL from
# app.moolre.com → Wallet Details → POS Link. Looks like
# https://pos.moolre.com/<slug>.
MOOLRE_POS_URL=

# Moolre auto-credit webhook (recommended). The Secret Key from Moolre
# dashboard → Callbacks signs every payload so we can trust the
# transaction succeeded before crediting the player. Without it the
# webhook route refuses every request.
#
# Setup:
#   1. Moolre dashboard → Callbacks → Callback URL =
#        https://<your-app>/api/payments/moolre/callback
#   2. Copy the Secret Key into MOOLRE_SECRET_KEY below.
#
# The Public / Private keys are reserved for the transaction-init API and
# are unused by the webhook-only flow; leave them blank if you only want
# auto-credit after a Moolre POS payment.
MOOLRE_SECRET_KEY=
MOOLRE_PUBLIC_KEY=
MOOLRE_PRIVATE_KEY=
MOOLRE_ACCOUNT_NUMBER=

# Paystack — Nigeria / Kenya / South Africa wallets. Get keys from
# dashboard.paystack.com → Settings → API Keys & Webhooks. The public key
# is browser-safe; the secret key is server-side only.
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# Optional: absolute URL of this app (e.g. https://primebet.example.com)
# used to build the Paystack callback. Defaults to the request origin.
NEXT_PUBLIC_APP_URL=

# Minimum first deposit — legacy single-number var still applies to Ghana
# users. Other countries default to the values in lib/countries.ts; override
# per country with MIN_FIRST_DEPOSIT_NG, MIN_FIRST_DEPOSIT_KE,
# MIN_FIRST_DEPOSIT_ZA. Same pattern for VERIFICATION_AMOUNT_<CC>.
MIN_FIRST_DEPOSIT=200
# MIN_FIRST_DEPOSIT_NG=30000
# MIN_FIRST_DEPOSIT_KE=2500
# MIN_FIRST_DEPOSIT_ZA=350
# VERIFICATION_AMOUNT_GH=200
# VERIFICATION_AMOUNT_NG=30000
# VERIFICATION_AMOUNT_KE=2500
# VERIFICATION_AMOUNT_ZA=350

# Supabase (https://supabase.com) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never commit; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Customer Service / Contact Support button → opens t.me/<handle>.
# Leave unset to default to "PrimeBet_Africa". Just the username, no @ or URL.
NEXT_PUBLIC_TELEGRAM_SUPPORT_HANDLE=PrimeBet_Africa
